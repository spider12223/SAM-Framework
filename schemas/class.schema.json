  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*:[a-z][a-z0-9_]*$",
      "description": "Unique class id in 'namespace:class' form (e.g. 'darkblade:assassin'). S.A.M assigns the runtime numeric class id (>=1000) automatically."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Display name shown on the class-select screen."
    },
    "description": {
      "type": "string",
      "description": "Flavor/description text shown for the class."
    },
    "portrait": {
      "type": "string",
      "description": "Optional path (relative to the mod folder) to a PNG used as this class's icon on the character-select carousel, e.g. 'portraits/assassin.png'. A 54x54 PNG matches the vanilla class icons exactly; the image is drawn centered at native size and cropped to the 54x54 button, so other sizes still work. If omitted, or the file cannot be found at load time, S.A.M falls back to a placeholder icon."
    },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "description": "Attribute and HP/MP modifiers applied when a player picks this class (added to the race base). Any omitted key defaults to 0.",
      "properties": {
        "STR": {
          "type": "integer",
          "description": "STR attribute modifier added on top of the player's race base (matches 'stat->STR += n' in initClassStats). May be negative."
        },
        "DEX": {
          "type": "integer",
          "description": "DEX attribute modifier added on top of the player's race base (matches 'stat->DEX += n' in initClassStats). May be negative."
        },
        "CON": {
          "type": "integer",
          "description": "CON attribute modifier added on top of the player's race base (matches 'stat->CON += n' in initClassStats). May be negative."
        },
        "INT": {
          "type": "integer",
          "description": "INT attribute modifier added on top of the player's race base (matches 'stat->INT += n' in initClassStats). May be negative."
        },
        "PER": {
          "type": "integer",
          "description": "PER attribute modifier added on top of the player's race base (matches 'stat->PER += n' in initClassStats). May be negative."
        },
        "CHR": {
          "type": "integer",
          "description": "CHR attribute modifier added on top of the player's race base (matches 'stat->CHR += n' in initClassStats). May be negative."
        },
        "HP": {
          "type": "integer",
          "description": "Modifier to maximum health (maps to Stat::MAXHP). May be negative."
        },
        "MP": {
          "type": "integer",
          "description": "Modifier to maximum mana (maps to Stat::MAXMP). May be negative."
        }
      }
    },
    "skills": {
      "type": "object",
      "additionalProperties": false,
      "description": "Starting skill proficiencies. Keys are PRO_ constants from stat.hpp; values are 0-100. Any omitted skill defaults to 0 (untrained).",
      "properties": {
        "PRO_LOCKPICKING": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "description": "Lockpicking proficiency, 0-100 (maps to PRO_LOCKPICKING in stat.hpp). Base attribute: DEX."
        },
        "PRO_STEALTH": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "description": "Stealth proficiency, 0-100 (maps to PRO_STEALTH in stat.hpp). Base attribute: DEX."
        },
        "PRO_TRADING": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "description": "Trading proficiency, 0-100 (maps to PRO_TRADING in stat.hpp). Base attribute: CHR."
        },
        "PRO_APPRAISAL": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "description": "Appraisal proficiency, 0-100 (maps to PRO_APPRAISAL in stat.hpp). Base attribute: PER."
        },
        "PRO_THAUMATURGY": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "description": "Thaumaturgy (divine casting) proficiency, 0-100 (maps to PRO_THAUMATURGY in stat.hpp). Base attribute: CON."
        },
        "PRO_LEADERSHIP": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "description": "Leadership proficiency, 0-100 (maps to PRO_LEADERSHIP in stat.hpp). Base attribute: CHR."
        },
        "PRO_MYSTICISM": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
