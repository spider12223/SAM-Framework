    "starting_items": {
      "type": "array",
      "description": "Items granted to the player when the class starts.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type"
        ],
        "description": "One starting item entry.",
        "properties": {
          "type": {
            "oneOf": [
              {
                "$ref": "#/definitions/itemType"
              },
              {
                "type": "string",
                "pattern": "^[a-z][a-z0-9_]*:[a-z][a-z0-9_]*$"
              }
            ],
            "description": "Item to grant: a vanilla ItemType name (e.g. 'IRON_AXE') or a custom S.A.M item id in 'namespace:item' form."
          },
          "status": {
            "enum": [
              "BROKEN",
              "DECREPIT",
              "WORN",
              "SERVICABLE",
              "EXCELLENT"
            ],
            "default": "SERVICABLE",
            "description": "Item condition (Barony Status enum, from items.hpp). Note the Barony spelling 'SERVICABLE'."
          },
          "beatitude": {
            "type": "integer",
            "default": 0,
            "description": "Blessedness: negative = cursed, 0 = uncursed, positive = blessed."
          },
          "count": {
            "type": "integer",
            "minimum": 1,
            "default": 1,
            "description": "How many of the item to grant (stack size)."
          },
          "appearance": {
            "type": "integer",
            "minimum": 0,
            "default": 0,
            "description": "Appearance/variant number selecting among model & name variations. Use 0 unless a specific variant is needed."
          },
          "identified": {
            "type": "boolean",
            "default": true,
            "description": "Whether the item starts identified."
          },
          "equip": {
            "type": "boolean",
            "default": false,
            "description": "If true, auto-equip the item on start (weapons/armor/rings); if false, place it in the inventory."
          },
          "hotbar_slot": {
            "type": "integer",
            "minimum": -1,
            "maximum": 9,
            "default": -1,
            "description": "Hotbar slot (0-9) to bind this item to, or -1 for none."
          }
        }
      }
    },
    "starting_spells": {
      "type": "array",
      "description": "Spells the class knows from the start.",
      "items": {
        "type": "string",
        "pattern": "^SPELL_[A-Z0-9_]+$",
        "description": "A Barony spell constant name in SPELL_X form (e.g. 'SPELL_FORCEBOLT'), from magic.hpp."
      }
    },
    "stat_growth": {
      "type": "object",
      "additionalProperties": false,
      "description": "Which attributes roll higher (strong) or lower (weak) on level-up.",
      "properties": {
        "strong_rolls": {
          "type": "array",
          "description": "Attributes that roll a HIGHER gain on level-up.",
          "items": {
            "enum": [
              "STR",
              "DEX",
              "CON",
              "INT",
              "PER",
              "CHR"
            ],
            "description": "An attribute name (STR/DEX/CON/INT/PER/CHR), mapping to STAT_STR..STAT_CHR in stat.hpp."
          }
        },
        "weak_rolls": {
          "type": "array",
          "description": "Attributes that roll a LOWER gain on level-up.",
          "items": {
            "enum": [
              "STR",
              "DEX",
              "CON",
              "INT",
              "PER",
              "CHR"
            ],
            "description": "An attribute name (STR/DEX/CON/INT/PER/CHR), mapping to STAT_STR..STAT_CHR in stat.hpp."
          }
        }
      }
    },
    "gold": {
      "type": "integer",
      "minimum": 0,
      "default": 0,
      "description": "Starting gold granted to the class."
    }
